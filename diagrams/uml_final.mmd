classDiagram
    class Task {
        +title: str
        +duration_minutes: int
        +priority: str
        +category: str
        +recurring: bool
        +completed: bool
        +time_of_day: str
        +pet_name: str
        +frequency: str
        +due_date: date
        +update_task(details: dict)
        +mark_complete() Task?
    }

    class Pet {
        +name: str
        +species: str
        +care_needs: str
        +tasks: List[Task]
        +add_task(task: Task)
        +get_task_summary() str
    }

    class Owner {
        +name: str
        +contact_info: str?
        +pets: List[Pet]
        +add_pet(pet: Pet)
        +get_all_tasks() List[Task]
        +view_daily_plan() str
    }

    class Scheduler {
        +available_time_minutes: int
        +tasks: List[Task]
        +generate_daily_plan(owner: Owner) List[Task]
        +explain_plan(owner: Owner) str
        +sort_by_time(tasks: List[Task]) List[Task]
        +filter_tasks(tasks: List[Task], completed: bool?, pet_name: str?) List[Task]
        +detect_conflicts(tasks: List[Task]) List[str]
        -_priority_rank(priority: str) int
        -_time_to_minutes(time_of_day: str) int
    }

